# ~/.gitconfig — managed in the dotfiles repo (git/gitconfig)
#
# Machine-specific overrides (work identity, proxy settings) belong in
# ~/.gitconfig.local — included at the bottom, so it wins over everything.

# ═══ Identity ═══

[user]
    name = Jason Feng
    email = jasonfungsing@gmail.com

# ═══ Core ═══

[core]
    excludesfile = ~/.gitignore_global
    ignorecase = false
    editor = nvim

[init]
    defaultBranch = main

# ═══ Diff & merge ═══

[diff]
    tool = vscode
    algorithm = patience

[difftool]
    prompt = false

[difftool "vscode"]
    cmd = code --wait --diff \"$LOCAL\" \"$REMOTE\"

[merge]
    tool = vscode

[mergetool]
    prompt = false

[mergetool "vscode"]
    cmd = code --wait --merge \"$LOCAL\" \"$REMOTE\" \"$BASE\" \"$MERGED\"

# ═══ Workflow behaviour ═══

[push]
    default = simple
    autoSetupRemote = true

[pull]
    ff = only
    rebase = true

[rebase]
    instructionFormat = "[%an - %ar] %s"
    autoStash = true

# ═══ Integrations ═══

[credential]
    helper = osxkeychain

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

# ═══ Aliases ═══

[alias]
    # Status & inspection
    s = status
    d = diff
    tree = log --oneline --branches --remotes --tags --graph --abbrev-commit --author-date-order --decorate --format=format:'%C(bold blue)%h%C(reset) %C(reset)%C(bold yellow)%d%C(reset) - %C(dim white)%aD (%ar)%C(reset)%n'' %C(bold cyan)%s%C(reset) %C(white)- %an%C(reset)%C(white) <%ae%C(reset)%C(white)>'

    # Everyday flow
    cl = clone
    co = checkout
    p = pull
    pa = pull --all
    ph = push
    f = fetch
    fa = fetch --all
    aa = add --all
    al = add --patch
    c = commit
    cm = commit -m
    ca = commit --amend
    undo = reset --soft HEAD~1

    # Branches
    b = branch
    bd = branch -d
    bD = branch -D
    rbom = rebase origin/master
    cleanup = "!git fetch -p origin && git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -D"

    # Review helpers
    pr = "!f() { git fetch origin pull/$1/head:pr/$1 && git checkout pr/$1; }; f"

    # Diff/merge tool shortcuts — default (vscode); postfix "v" for nvim
    dk = difftool
    dkc = difftool --cached
    mk = mergetool
    dkv = difftool --tool=nvimdiff
    dkcv = difftool --tool=nvimdiff --cached
    mkv = mergetool --tool=nvimdiff

# ═══ Machine-local ═══

[include]
    path = ~/.gitconfig.local
