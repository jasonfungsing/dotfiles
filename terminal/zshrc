# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

alias t='tmux'
alias mux="tmuxinator"
alias gpa="find . -mindepth 1 -maxdepth 1 -type d -print -exec git -C {} pull \;"
alias update="brew update; brew upgrade --yes; brew upgrade --cask --greedy --yes; brew cleanup; omz update; nvim +Lazy sync +qa"
alias u=update
alias vu="nvim +Lazy sync +qa"
alias y="yarn"
alias v="nvim"
alias i="idea"
alias weather='f() { curl wttr.in/$1. };f'
alias k=kubectl
alias python=python3
alias mnk=minikube
alias gc=gcloud
alias nosleep="sudo pmset -a disablesleep 1 && echo '☕Sleep disabled'"
alias yessleep="sudo pmset -a disablesleep 0 && echo '💤 Sleep enabled'"

# Check MacBook lid sleep status
sleepstatus() {
  val=$(pmset -g | awk '/SleepDisabled/ {print $2}')
  if [[ "$val" == "1" ]]; then
    echo "☕ Sleep DISABLED — Mac stays awake when closed"
  else
    echo "💤 Sleep ENABLED — default behavior (sleeps on lid close)"
  fi
}

prompt_context() {
  prompt_segment white black "%(!.%{%F{yellow}%}.)$DEFAULT_USER"
}

# (Intel-era /usr/local exports removed — those keg paths don't exist on
# Apple Silicon, and /usr/local/bin is already in the base PATH)
export PATH="$BREW_PREFIX/sbin:$PATH"
export PATH="$BREW_PREFIX/bin:$PATH"

export EDITOR='nvim'
export VISUAL='nvim'

# Auto complete for kubernetes
if [ $commands[kubectl] ]; then
  source <(kubectl completion zsh)
fi

# Auto complete for git
[[ -r "$BREW_PREFIX/etc/profile.d/bash_completion.sh" ]] && . "$BREW_PREFIX/etc/profile.d/bash_completion.sh"

[ -f "$BREW_PREFIX/etc/profile.d/autojump.sh" ] && . "$BREW_PREFIX/etc/profile.d/autojump.sh"

export NVM_DIR="$HOME/.nvm"
[ -s "$BREW_PREFIX/opt/nvm/nvm.sh" ] && \. "$BREW_PREFIX/opt/nvm/nvm.sh"  # This loads nvm
[ -s "$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

if type brew &>/dev/null; then
  FPATH=$(brew --prefix)/share/zsh/site-functions:$FPATH
fi

# Add Docker completions to fpath
fpath=($HOME/.docker/completions $fpath)

# Initialise completion system with caching: full rebuild if the dump is
# missing or older than a day, otherwise trust the cache (-C, fast)
autoload -Uz compinit
_zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
if [ ! -f "$_zcompdump" ] || [ -n "$(find "$_zcompdump" -mtime +0 2>/dev/null)" ]; then
  compinit
else
  compinit -C
fi
unset _zcompdump

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
eval "$(direnv hook zsh)"

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/path.zsh.inc' ]; then . '/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/completion.zsh.inc' ]; then . '/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/completion.zsh.inc'; fi

# Load private config files
if [ -f ~/.zshrc.private ]; then
  source ~/.zshrc.private
fi

# Added by Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# Added by Antigravity IDE
export PATH="$HOME/.antigravity-ide/antigravity-ide/bin:$PATH"
