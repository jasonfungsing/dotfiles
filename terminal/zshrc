# ~/.zshrc — managed in the dotfiles repo (terminal/zshrc)
#
#   1. Pre-init guards
#   2. Homebrew prefix & fpath
#   3. Oh-My-Zsh
#   4. PATH
#   5. Environment
#   6. Aliases
#   7. Functions
#   8. Completions & tool hooks
#   9. Private / machine-local
#
# Order matters: sections 1–2 must run before Oh-My-Zsh loads (it calls
# compinit at load time), and completions register after compinit runs.

# ═══ 1. Pre-init guards ═══

# Suppress compinstall/compfix prompts from system zsh initialisation
skip_global_compinit=1
SKIP_COMPFIX=true
ZSH_DISABLE_COMPFIX=true
unsetopt promptcr

# ═══ 2. Homebrew prefix & fpath ═══

BREW_PREFIX="/opt/homebrew"                           # Apple Silicon
[ -d "$BREW_PREFIX" ] || BREW_PREFIX="/usr/local"     # Intel

# Keep fpath valid across brew zsh upgrades: an upgrade deletes the old
# versioned Cellar function dir that running shells point at, breaking
# compinit on re-source. The unversioned share path is stable, and must be
# added BEFORE oh-my-zsh loads.
[ -d "$BREW_PREFIX/share/zsh/functions" ] && fpath=($BREW_PREFIX/share/zsh/functions $fpath)
[ -d "$BREW_PREFIX/share/zsh/site-functions" ] && fpath=($BREW_PREFIX/share/zsh/site-functions $fpath)
[ -d "$BREW_PREFIX/share/zsh-completions" ] && fpath=($BREW_PREFIX/share/zsh-completions $fpath)
[ -d "$HOME/.docker/completions" ] && fpath=($HOME/.docker/completions $fpath)

# A shell that survived a zsh upgrade still holds function stubs tied to the
# deleted files; drop them so they re-resolve from the current fpath when
# this file is re-sourced. No-op in fresh shells (nothing loaded yet).
unfunction compinit bashcompinit compdump compaudit 2>/dev/null

# ═══ 3. Oh-My-Zsh ═══

export ZSH=~/.oh-my-zsh
ZSH_THEME="cobalt2"
export UPDATE_ZSH_DAYS=30
plugins=(git tmux brew npm macos gitignore golang mvn python xcode z tmuxinator kubectl autojump dotenv)

source $ZSH/oh-my-zsh.sh

# Override cobalt2's user@host prompt segment
prompt_context() {
  prompt_segment white black "%(!.%{%F{yellow}%}.)$DEFAULT_USER"
}

# Alias reminder (Enter-key widget). Must load AFTER oh-my-zsh: omz forces
# the emacs keymap (bindkey -e); loaded earlier, a shell that starts in vi
# mode (EDITOR set, e.g. inside tmux) would bind the widget into the unused
# viins keymap and the reminder would silently never fire.
source ~/.alias_prompt.sh

# ═══ 4. PATH ═══

export PATH="$BREW_PREFIX/sbin:$PATH"
export PATH="$BREW_PREFIX/bin:$PATH"

# Antigravity CLI + IDE
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"
export PATH="$HOME/.antigravity-ide/antigravity-ide/bin:$PATH"

# ═══ 5. Environment ═══

export EDITOR='nvim'
export VISUAL='nvim'
export NVM_DIR="$HOME/.nvm"

# ═══ 6. Aliases ═══

# Terminal & multiplexing
alias t='tmux'
alias mux="tmuxinator"

# Editors & dev tools
alias v="nvim"
alias y="yarn"
alias python=python3

# Update everything (brew, oh-my-zsh, neovim plugins).
# The nvim part must be quoted as one arg ("+Lazy! sync") — unquoted, nvim
# treats "sync" as a filename and never updates anything. Lazy! waits for
# the sync to finish; --headless prints progress inline in the terminal.
alias update='brew update; brew upgrade --yes; brew upgrade --cask --greedy --yes; brew cleanup; omz update; nvim --headless "+Lazy! sync" +qa; echo "\n✅ Update complete"'
alias u=update
alias vu='nvim --headless "+Lazy! sync" +qa'

# Git
alias gpa="find . -mindepth 1 -maxdepth 1 -type d -print -exec git -C {} pull \;"

# Cloud & Kubernetes
alias k=kubectl
alias mnk=minikube

# macOS sleep control (needs sudo; check current state with sleepstatus)
# nosleep:  keep the Mac awake — even with the lid closed — but ONLY while
#           on AC power (-c). On battery it sleeps normally, so a closed
#           laptop in a bag won't cook itself. Persists until yessleep.
# yessleep: restore normal sleep behaviour on all power sources (-a).
alias nosleep="sudo pmset -c disablesleep 1 && echo '☕ Sleep disabled while on AC power (battery behaviour unchanged)'"
alias yessleep="sudo pmset -a disablesleep 0 && echo '💤 Sleep enabled'"

# Misc
alias weather='f() { curl wttr.in/$1. };f'

# ═══ 7. Functions ═══

# Is the MacBook lid closed? Prints "Yes" or "No" — handy over SSH or in
# scripts to check the laptop's physical state (clamshell mode).
islidclosed() {
  ioreg -r -k AppleClamshellState | awk '/AppleClamshellState/ {print $NF}'
}

# Check MacBook lid sleep status
sleepstatus() {
  val=$(pmset -g | awk '/SleepDisabled/ {print $2}')
  if [[ "$val" == "1" ]]; then
    echo "☕ Sleep DISABLED — Mac stays awake even when lid closed"
  else
    echo "💤 Sleep ENABLED — default behavior (sleeps on lid close)"
  fi
}

# Ctrl+/ or F1: dynamic shortcut sheet — searchable list of the CURRENT
# shell's aliases, functions, and key bindings, generated live (never goes
# stale). Inside tmux, the tmux bindings are included too.
# Enter on an alias/function line puts it on the prompt, ready to run;
# Enter on a tmux line executes that binding immediately.
shortcut-sheet() {
  local sel
  sel=$({
    if [ -n "$TMUX" ]; then
      echo "═══ tmux (C-f = prefix) ═══"
      # Raw bindings merged with their -N notes, shown as [description]
      {
        tmux list-keys -N -T prefix 2>/dev/null
        echo "@@ALLNOTES@@"
        tmux list-keys -N 2>/dev/null
        echo "@@PREFIX@@"
        tmux list-keys -T prefix 2>/dev/null
        echo "@@ROOT@@"
        tmux list-keys -T root 2>/dev/null | grep -viE "mouse|click|wheel|scrollbar"
        echo "@@COPY@@"
        tmux list-keys -T copy-mode-vi 2>/dev/null | grep -viE "mouse|click|wheel|scrollbar"
      } | awk '
        function lk(s) { gsub(/\\/, "", s); return s }
        /^@@ALLNOTES@@$/ { sec=1; next }
        /^@@PREFIX@@$/   { sec=2; next }
        /^@@ROOT@@$/     { sec=3; next }
        /^@@COPY@@$/     { sec=4; next }
        sec==0 { k=lk($2); $1=""; $2=""; sub(/^ +/, ""); pn[k]=$0; next }
        sec==1 {
          # combined view is the only place root-table notes appear (shown
          # with a bogus prefix column); keep those not already in pn
          k=lk($2); if (!(k in pn)) { $1=""; $2=""; sub(/^ +/, ""); rn[k]=$0 }
          next
        }
        sec==2 {
          sub(/^bind-key +(-r +)?-T prefix +/, "")
          k=$1; key=lk(k); sub(/^\\/, "", k)
          cmd=$0; sub(/^[^ ]+ +/, "", cmd)
          note=(key in pn ? "[" pn[key] "]" : "")
          printf "tmux   %-12s %-48s %s\n", "C-f " k, note, cmd
          next
        }
        sec==3 {
          sub(/^bind-key +(-n +)?-T root +/, "")
          k=$1; key=lk(k); sub(/^\\/, "", k)
          cmd=$0; sub(/^[^ ]+ +/, "", cmd)
          note=(key in rn ? "[" rn[key] "]" : "")
          printf "tmux   %-12s %-48s %s\n", k, note, cmd
          next
        }
        sec==4 {
          sub(/^bind-key +-T copy-mode-vi +/, "")
          k=$1; sub(/^\\/, "", k)
          cmd=$0; sub(/^[^ ]+ +/, "", cmd)
          printf "tmux   %-12s %-48s %s\n", "copy " k, "", cmd
          next
        }'
      echo ""
    fi
    echo "═══ Aliases (alias → what it runs) ═══"
    alias | sort | awk '{
      i = index($0, "=")
      name = substr($0, 1, i - 1); val = substr($0, i + 1)
      q = sprintf("%c", 39)  # single quote
      if (substr(val, 1, 1) == q && substr(val, length(val), 1) == q)
        val = substr(val, 2, length(val) - 2)
      printf "alias  %-16s %s\n", name, val
    }'
    echo ""
    echo "═══ Functions ═══"
    # Third column: curated description for our own functions, otherwise
    # the function's origin (whence -v) — live truth, no drift
    local f src fdesc
    for f in ${(ko)functions}; do
      [[ "$f" == _* ]] && continue
      fdesc=""
      case "$f" in
        shortcut-sheet)         fdesc="THIS sheet" ;;
        islidclosed)            fdesc="print Yes/No — is the MacBook lid closed" ;;
        sleepstatus)            fdesc="report whether sleep is currently disabled" ;;
        check-alias-and-accept) fdesc="Enter-key widget: suggests the alias if one exists" ;;
        fuck)                   fdesc="correct the previous command (thefuck)" ;;
        nvm)                    fdesc="Node version manager" ;;
        *)
          src=$(whence -v -- "$f" 2>/dev/null)
          case "$src" in
            *oh-my-zsh/plugins/*) fdesc="from omz plugin: ${${src##*oh-my-zsh/plugins/}%%/*}" ;;
            *oh-my-zsh/*)         fdesc="from oh-my-zsh core" ;;
            *cobalt2*)            fdesc="from the cobalt2 theme" ;;
            *autojump*)           fdesc="from autojump" ;;
            *fzf*)                fdesc="from fzf" ;;
            *nvm*)                fdesc="from nvm" ;;
            *iterm2*)             fdesc="from iTerm2 shell integration" ;;
            *"shell function from"*) fdesc="from ${${src##*shell function from }/#$HOME/~}" ;;
          esac
          ;;
      esac
      printf "func   %-24s %s\n" "$f" "$fdesc"
    done
    echo ""
    echo "═══ Key bindings (^=Ctrl, ^[=Option/Esc) ═══"
    bindkey | grep -v self-insert | awk '
      BEGIN {
        d["shortcut-sheet"]="THIS sheet"
        d["accept-line"]="run the command"
        d["check-alias-and-accept"]="run command, but suggest the alias if one exists"
        d["fzf-history-widget"]="fuzzy-search command history"
        d["fzf-file-widget"]="fuzzy-find file, insert path"
        d["fzf-cd-widget"]="fuzzy-pick directory and cd"
        d["fzf-completion"]="complete (fzf-aware)"
        d["beginning-of-line"]="go to start of line"
        d["end-of-line"]="go to end of line"
        d["backward-char"]="move left one char"
        d["forward-char"]="move right one char"
        d["backward-word"]="move back one word"
        d["forward-word"]="move forward one word"
        d["backward-delete-char"]="delete char before cursor"
        d["delete-char-or-list"]="delete char / list completions"
        d["backward-kill-word"]="delete word before cursor"
        d["kill-word"]="delete word after cursor"
        d["kill-line"]="delete to end of line"
        d["kill-whole-line"]="delete the whole line"
        d["kill-buffer"]="delete everything typed"
        d["yank"]="paste last deleted text"
        d["yank-pop"]="cycle older deleted text after paste"
        d["undo"]="undo last edit"
        d["transpose-chars"]="swap the two chars around cursor"
        d["transpose-words"]="swap the two words around cursor"
        d["up-case-word"]="UPPERCASE word"
        d["down-case-word"]="lowercase word"
        d["capitalize-word"]="Capitalise word"
        d["clear-screen"]="clear the screen"
        d["history-incremental-search-backward"]="search history as you type (older)"
        d["history-incremental-search-forward"]="search history as you type (newer)"
        d["up-line-or-beginning-search"]="previous history entry matching typed prefix"
        d["down-line-or-beginning-search"]="next history entry matching typed prefix"
        d["history-search-backward"]="previous command with same first word"
        d["history-search-forward"]="next command with same first word"
        d["insert-last-word"]="insert last argument of previous command"
        d["magic-space"]="space, expanding !! style history refs"
        d["expand-history"]="expand !! style history refs"
        d["push-line"]="stash line, restore after next command"
        d["accept-and-hold"]="run line but keep it on the prompt"
        d["accept-line-and-down-history"]="run line, queue next from history"
        d["run-help"]="open man page for current command"
        d["which-command"]="describe the command"
        d["quoted-insert"]="insert next keypress literally"
        d["exchange-point-and-mark"]="jump between cursor and mark"
        d["set-mark-command"]="set mark at cursor"
        d["copy-prev-shell-word"]="duplicate previous word"
        d["reverse-menu-complete"]="cycle completion menu backwards"
        d["bracketed-paste"]="paste"
        d["edit-command-line"]="edit the command line in nvim"
      }
      {
        key=$1; w=$2
        printf "zsh    %-16s %-44s %s\n", key, w, (w in d ? d[w] : "")
      }'
  } | fzf --exact --reverse --no-sort --prompt="shortcuts> " \
        --bind "tab:down,btab:up,ctrl-j:ignore,ctrl-k:ignore" \
        --header="Enter: tmux/zsh line → run | alias/func → to prompt | move: Tab / Shift + Tab")

  case "$sel" in
    alias*) LBUFFER="${${(z)sel}[2]}" ;;
    func*)  LBUFFER="${${(z)sel}[2]}" ;;
    "tmux   copy "*) ;;  # copy-mode commands need copy-mode context — view only
    tmux*)
      # Columns: tag | key | [description] | command — strip the first
      # three; the remainder is valid tmux command syntax by design
      local cmd
      cmd=$(print -r -- "$sel" | sed -E 's/^tmux +(C-f +)?[^ ]+ +(\[[^]]*\] +)?//')
      [ -n "$cmd" ] && eval "command tmux $cmd" > /dev/null 2>&1
      ;;
    zsh*)
      # ZLE widgets act on the prompt itself — invoke the selected one
      # right here (string macros, a quoted 3rd column, are skipped)
      local w="${${(z)sel}[3]}"
      if [[ -n "$w" && "$w" != \"* ]]; then
        zle reset-prompt
        zle "$w" 2> /dev/null
        return
      fi
      ;;
  esac
  zle reset-prompt
}
zle -N shortcut-sheet
bindkey "^_" shortcut-sheet      # Ctrl+/ (terminals send ^_ for it)
bindkey "^[OP" shortcut-sheet    # F1 (application mode)
bindkey "^[[11~" shortcut-sheet  # F1 (some terminals)

# ═══ 8. Completions & tool hooks ═══

# Initialise completion system with caching: full rebuild if the dump is
# missing or older than a day, otherwise trust the cache (-C, fast)
autoload -Uz compinit
_zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
if [ ! -f "$_zcompdump" ] || [ -n "$(find "$_zcompdump" -mtime +0 2>/dev/null)" ]; then
  compinit
else
  compinit -C
fi
unset _zcompdump


# bash-style completions (used by nvm below)
[[ -r "$BREW_PREFIX/etc/profile.d/bash_completion.sh" ]] && . "$BREW_PREFIX/etc/profile.d/bash_completion.sh"

# autojump
[ -f "$BREW_PREFIX/etc/profile.d/autojump.sh" ] && . "$BREW_PREFIX/etc/profile.d/autojump.sh"

# nvm
[ -s "$BREW_PREFIX/opt/nvm/nvm.sh" ] && \. "$BREW_PREFIX/opt/nvm/nvm.sh"
[ -s "$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# direnv
eval "$(direnv hook zsh)"

# thefuck — type `fuck` to correct the previous command (guarded: skipped
# on machines where it isn't installed)
command -v thefuck > /dev/null && eval "$(thefuck --alias)"


# ═══ 9. Private / machine-local (not tracked in git) ═══

if [ -f ~/.zshrc.private ]; then
  source ~/.zshrc.private
fi
